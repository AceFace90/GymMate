{
  "expo": {
    "name": "GymMate",
    "slug": "gymmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.gymmate"
    },
    "android": {
      "package": "com.yourname.gymmate"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/logo.png",
      "name": "GymMate",
      "shortName": "GymMate",
      "description": "Build programs. Log sessions. Track PRs.",
      "themeColor": "#1a1a1a",
      "backgroundColor": "#1a1a1a",
      "baseUrl": "/GymMate"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "GymMate uses your photos to identify exercises from images.",
          "cameraPermission": "GymMate uses your camera to identify gym machines and exercises."
        }
      ]
    ]
  }
}
