{
  "expo": {
    "name": "GymMate",
    "slug": "gymmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.gymmate"
    },
    "android": {
      "package": "com.yourname.gymmate"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "name": "GymMate",
      "shortName": "GymMate",
      "description": "Build programs. Log sessions. Track PRs.",
      "themeColor": "#1a1a1a",
      "backgroundColor": "#1a1a1a",
      "baseUrl": "/gymmate"
    },
    "plugins": []
  }
}
