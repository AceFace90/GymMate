rules_version = '2';

// GymMate Firestore security rules.
//
// The entire data model is one document per user at users/{uid} (see
// src/services/cloudSync.js). A signed-in user may read and write ONLY their
// own document — uid in the path must equal their authenticated uid. Everything
// else is denied by default.
//
// HOW TO APPLY: paste this into Firebase console → Build → Firestore Database →
// Rules → Publish. (Or deploy via the Firebase CLI: `firebase deploy --only firestore:rules`.)

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Deny everything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
